# Supabase — Prisma pooled connection (pgbouncer=true)
# Get from: Supabase → Project Settings → Database → Connection pooling
# Store as SENSITIVE in Vercel dashboard
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — direct connection (used by Prisma for migrations)
# Get from: Supabase → Project Settings → Database → Direct connection
# Store as SENSITIVE in Vercel dashboard
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Upstash Redis REST — URL
# Get from: Upstash console → Database → REST API
# Store as SENSITIVE in Vercel dashboard
UPSTASH_REDIS_REST_URL="https://<id>.upstash.io"

# Upstash Redis REST — token
# Get from: Upstash console → Database → REST API
# Store as SENSITIVE in Vercel dashboard
UPSTASH_REDIS_REST_TOKEN="<your-token>"

# Cron secret — used to authenticate Vercel cron job requests
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Add to: Vercel project env vars (all environments) + .env.local
CRON_SECRET="<your-random-secret>"
